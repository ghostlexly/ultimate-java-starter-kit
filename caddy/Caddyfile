{
# Disable admin API for security
    admin off

    debug
    log {
            output stdout
            format console
        }
}

# Hosts

localhost, http://tunnel.lunisoft.fr {
# File upload size limit - 100MB for large file uploads
    request_body {
                     max_size 100MB
                 }

# Security and custom headers
    header {
           # Your custom branding
               X-Powered-By "LUNISOFT - contact@lunisoft.fr"

           # Security headers
               X-Frame-Options "SAMEORIGIN"
               X-Content-Type-Options "nosniff"
               X-XSS-Protection "1; mode=block"

           # Hide Caddy server info
               -Server
           }

# Gzip compression for better performance
    encode {
               gzip
               minimum_length 1024
           }

# API routes -> Backend (configurable via BACKEND_UPSTREAM env var)
# - Dev: host.docker.internal:3000 (IDE on host machine)
# - Prod: backend:3000 (Docker container)
    handle /api/* {
                      reverse_proxy {$BACKEND_UPSTREAM:java-starter-backend:3000}
                  }

# All other routes -> Frontend
    handle {
               reverse_proxy java-starter-frontend:3000
           }

# Error handling
    handle_errors {
                      @5xx expression `{http.error.status_code} >= 500`
                      handle @5xx {
                                      respond "Service temporarily unavailable" 503
                                  }
                  }
}

# JobRunr Dashboard

localhost:8000 {
    handle {
               reverse_proxy java-starter-backend:8000
           }
}
